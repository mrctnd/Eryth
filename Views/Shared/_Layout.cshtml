<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Eryth</title>
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    <meta name="__RequestVerificationToken" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />

    <!-- Tailwind CSS -->
    <link href="~/css/output.css?v=@(DateTime.Now.Ticks)" rel="stylesheet" />

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/audioPlayer.css?v=@(DateTime.Now.Ticks)" rel="stylesheet" />
</head>
<body class="bg-black text-white font-sans min-h-screen">

    <!-- Page Transition Overlay -->
    <div id="page-transition" class="fixed inset-0 bg-black z-[100] opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out">
        <div class="flex items-center justify-center h-full">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 z-50 h-16 navbar-glass">
        <div class="max-w-7xl mx-auto flex items-center justify-between h-full px-6">

            <!-- Left: Logo -->
            <a href="/" class="flex items-center gap-2.5 flex-shrink-0 no-underline">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 bg-accent">
                    <i data-lucide="music-2" class="w-4 h-4 text-black"></i>
                </div>
                <span class="text-lg font-bold text-white tracking-tight">Eryth</span>
            </a>

            <!-- Center: Navigation Links + Search Bar -->
            <div class="flex items-center gap-1">
                <!-- Navigation Links -->
                <a href="/" class="nav-pill" id="nav-home">Ana Sayfa</a>
                <a href="/explore" class="nav-pill" id="nav-feed">Keşfet</a>
                <a href="/library" class="nav-pill" id="nav-library">Kütüphane</a>

                <!-- Search Bar -->
                <div class="ml-2 w-64">
                    <form method="get" action="/Search">
                        <div class="relative">
                            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500 pointer-events-none"></i>
                            <input type="text" name="q"
                                   placeholder="Şarkı, sanatçı, albüm ara..."
                                   class="search-input"
                                   aria-label="Sitede ara"
                                   id="navbar-search-input"
                                   autocomplete="off"
                                   value="@(Context.Request.Query["q"].FirstOrDefault() ?? "")">
                            <!-- Search suggestions dropdown -->
                            <div id="search-suggestions" class="hidden absolute top-full left-0 right-0 mt-2 dropdown-panel py-2 z-50 max-h-64 overflow-y-auto">
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Right: User Actions -->
            <div class="flex items-center gap-2" id="user-actions">

                <!-- Logged In State -->
                <div id="logged-in-actions" class="@(User.Identity?.IsAuthenticated == true ? "" : "hidden")">
                    <div class="flex items-center gap-2">

                        <!-- Upload CTA -->
                        <a href="/Track/Upload" class="upload-btn">
                            <i data-lucide="upload" class="w-3.5 h-3.5"></i>
                            <span>Yükle</span>
                        </a>

                        <!-- Notifications -->
                        <div class="relative" id="notifications-dropdown">
                            <button class="navbar-icon-btn" onclick="toggleDropdown('notifications-menu')" title="Bildirimler">
                                <i data-lucide="bell" class="w-4 h-4"></i>
                            </button>
                            <div id="notifications-menu" class="hidden dropdown-panel absolute right-0 mt-2 w-80 py-1">
                                <div class="px-4 py-3 dropdown-divider-bottom">
                                    <h3 class="text-sm font-semibold text-white">Bildirimler</h3>
                                </div>
                                <div class="max-h-64 overflow-y-auto">
                                    <div class="px-4 py-10 text-center">
                                        <i data-lucide="bell-off" class="w-7 h-7 mx-auto mb-2 text-gray-600"></i>
                                        <p class="text-xs text-gray-500">Yeni bildirim yok</p>
                                    </div>
                                </div>
                                <div class="px-4 py-2 dropdown-divider-top">
                                    <a href="@Url.Action("Index", "Notification")" class="text-xs font-medium text-accent hover:text-accent-dark transition-colors">Tüm bildirimleri görüntüle</a>
                                </div>
                            </div>
                        </div>

                        <!-- Messages -->
                        <div class="relative" id="messages-dropdown">
                            <button class="navbar-icon-btn" onclick="toggleDropdown('messages-menu')" title="Mesajlar">
                                <i data-lucide="mail" class="w-4 h-4"></i>
                            </button>
                            <div id="messages-menu" class="hidden dropdown-panel absolute right-0 mt-2 w-80 py-1">
                                <div class="px-4 py-3 dropdown-divider-bottom">
                                    <h3 class="text-sm font-semibold text-white">Mesajlar</h3>
                                </div>
                                <div class="max-h-64 overflow-y-auto">
                                    <div class="px-4 py-10 text-center">
                                        <i data-lucide="mail-open" class="w-7 h-7 mx-auto mb-2 text-gray-600"></i>
                                        <p class="text-xs text-gray-500">Yeni mesaj yok</p>
                                    </div>
                                </div>
                                <div class="px-4 py-2 dropdown-divider-top">
                                    <a href="@Url.Action("Index", "Message")" class="text-xs font-medium text-accent hover:text-accent-dark transition-colors">Tüm mesajları görüntüle</a>
                                </div>
                            </div>
                        </div>

                        <!-- Profile + Dropdown -->
                        <div class="relative" id="profile-dropdown">
                            <button class="flex items-center gap-1.5 rounded-full p-1 hover:bg-white/10 transition-all duration-200" onclick="toggleDropdown('profile-menu')">
                                @await Component.InvokeAsync("UserProfileImage")
                                <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-gray-400 mr-0.5"></i>
                            </button>
                            <div id="profile-menu" class="hidden dropdown-panel absolute right-0 mt-2 w-52 py-1">
                                <a href="@Url.Action("Profile", "User", new { username = User.Identity?.Name })" class="dropdown-item">
                                    <i data-lucide="user" class="w-4 h-4"></i><span>Profil</span>
                                </a>
                                <a href="@Url.Action("LikedTracks", "User")" class="dropdown-item">
                                    <i data-lucide="heart" class="w-4 h-4"></i><span>Beğendiklerim</span>
                                </a>
                                <a href="@Url.Action("Comments", "User")" class="dropdown-item">
                                    <i data-lucide="message-circle" class="w-4 h-4"></i><span>Yorumlarım</span>
                                </a>
                                <a href="@Url.Action("MyPlaylists", "Playlist")" class="dropdown-item">
                                    <i data-lucide="list-music" class="w-4 h-4"></i><span>Çalma Listelerim</span>
                                </a>
                                <a href="@Url.Action("Following", "User", new { username = User.Identity?.Name })" class="dropdown-item">
                                    <i data-lucide="users" class="w-4 h-4"></i><span>Takip Ettiklerim</span>
                                </a>
                                <a href="@Url.Action("Index", "Album")" class="dropdown-item">
                                    <i data-lucide="disc-3" class="w-4 h-4"></i><span>Albümlerim</span>
                                </a>
                                <a href="@Url.Action("MyTracks", "Track")" class="dropdown-item">
                                    <i data-lucide="disc" class="w-4 h-4"></i><span>Şarkılarım</span>
                                </a>
                                <div class="dropdown-separator"></div>
                                <a href="@Url.Action("AccountSettings", "User")" class="dropdown-item">
                                    <i data-lucide="settings" class="w-4 h-4"></i><span>Ayarlar</span>
                                </a>
                                <a href="@Url.Action("About", "Home")" class="dropdown-item">
                                    <i data-lucide="info" class="w-4 h-4"></i><span>Hakkında</span>
                                </a>
                                <div class="dropdown-separator"></div>
                                <form action="/Auth/Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item dropdown-item-danger w-full text-left">
                                        <i data-lucide="log-out" class="w-4 h-4"></i><span>Çıkış Yap</span>
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Logged Out State -->
                <div id="logged-out-actions" class="@(User.Identity?.IsAuthenticated == true ? "hidden" : "flex items-center gap-2")">
                    <button onclick="showAuthModal('signin')"
                            class="text-sm font-medium text-gray-300 hover:text-white px-4 py-2 rounded-full hover:bg-white/10 transition-all duration-200">Giriş Yap</button>
                    <a href="/Auth/Register"
                       class="text-sm font-bold px-5 py-2 rounded-full transition-all duration-200 hover:scale-105 inline-block text-center bg-accent hover:bg-accent-dark text-black">Hesap Oluştur</a>
                </div>

            </div>
        </div>
    </nav>

    <!-- Auth Modal -->
    <div id="auth-modal" class="fixed inset-0 z-50 hidden">
        <!-- Background Overlay -->
        <div class="fixed inset-0 bg-black/80 backdrop-blur-sm" onclick="hideAuthModal()"></div>

        <!-- Modal Container -->
        <div class="fixed inset-0 flex items-center justify-center p-4">
            <div id="auth-content" class="bg-[#121212] rounded-2xl shadow-2xl w-full max-w-md p-8 transform transition-all duration-300 ease-out scale-95 opacity-0 border border-white/10">

                <!-- Sign In Form -->
                <div id="signin-form" class="hidden">
                    <div class="flex justify-between items-start mb-8">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <div class="w-6 h-6 rounded-md flex items-center justify-center bg-accent">
                                    <i data-lucide="music-2" class="w-3.5 h-3.5 text-black"></i>
                                </div>
                                <span class="text-xs font-semibold text-accent tracking-widest uppercase">Eryth</span>
                            </div>
                            <h2 class="text-white text-2xl font-bold mt-3">Tekrar Hoş Geldiniz</h2>
                            <p class="text-gray-500 text-sm mt-1">Hesabınıza giriş yapın</p>
                        </div>
                        <button onclick="hideAuthModal()" class="navbar-icon-btn mt-1">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>

                    <!-- Validation errors -->
                    <div id="signin-errors" class="hidden mb-5 p-3.5 rounded-xl" style="background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);">
                        <div class="flex items-center gap-2">
                            <i data-lucide="alert-circle" class="w-4 h-4 text-red-400 flex-shrink-0"></i>
                            <div class="text-red-300 text-sm" id="signin-error-message"></div>
                        </div>
                    </div>

                    <form action="/Auth/Login" method="post" class="space-y-4" id="signin-form-element">
                        @Html.AntiForgeryToken()

                        <div class="space-y-1.5">
                            <label for="signin-email" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">E-posta veya Kullanıcı Adı</label>
                            <div class="relative">
                                <input type="text" id="signin-email" name="EmailOrUsername"
                                       class="auth-input"
                                       placeholder="E-posta veya kullanıcı adı" required>
                                <i data-lucide="user" class="auth-input-icon w-4 h-4"></i>
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label for="signin-password" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">Şifre</label>
                            <div class="relative">
                                <input type="password" id="signin-password" name="Password" autocomplete="current-password"
                                       class="auth-input"
                                       placeholder="Şifreniz" required>
                                <i data-lucide="lock" class="auth-input-icon w-4 h-4"></i>
                            </div>
                        </div>

                        <div class="flex items-center justify-between pt-1">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" id="remember-me" name="RememberMe"
                                       class="w-4 h-4 rounded text-accent bg-white/10 border-white/20 focus:ring-accent focus:ring-1">
                                <span class="text-gray-400 text-sm">Beni hatırla</span>
                            </label>
                            <a href="#" onclick="showForgotPassword()" class="text-sm text-accent hover:text-accent-dark transition-colors font-medium">
                                Şifremi unuttum?
                            </a>
                        </div>

                        <button type="submit" class="w-full py-3 rounded-xl font-bold text-sm transition-all duration-200 hover:scale-[1.02] flex items-center justify-center gap-2 mt-2 bg-accent hover:bg-accent-dark text-black">
                            <i data-lucide="log-in" class="w-4 h-4"></i>
                            <span>Giriş Yap</span>
                        </button>

                        <div class="text-center pt-4 border-t border-white/10">
                            <p class="text-gray-500 text-sm mb-2">Hesabınız yok mu?</p>
                            <button type="button" onclick="switchAuthMode('signup')" class="text-sm text-accent hover:text-accent-dark font-semibold transition-colors">
                                Hesap Oluştur →
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Sign Up Form -->
                <div id="signup-form" class="hidden">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <div class="w-6 h-6 rounded-md flex items-center justify-center bg-accent">
                                    <i data-lucide="music-2" class="w-3.5 h-3.5 text-black"></i>
                                </div>
                                <span class="text-xs font-semibold text-accent tracking-widest uppercase">Eryth</span>
                            </div>
                            <h2 class="text-white text-2xl font-bold mt-3">Eryth'e Katıl</h2>
                            <p class="text-gray-500 text-sm mt-1">Müzik yolculuğuna başla</p>
                        </div>
                        <button onclick="hideAuthModal()" class="navbar-icon-btn mt-1">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>

                    <!-- Validation errors -->
                    <div id="signup-errors" class="hidden mb-5 p-3.5 rounded-xl" style="background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);">
                        <div class="flex items-center gap-2">
                            <i data-lucide="alert-circle" class="w-4 h-4 text-red-400 flex-shrink-0"></i>
                            <div class="text-red-300 text-sm" id="signup-error-message"></div>
                        </div>
                    </div>

                    <form action="/Auth/Register" method="post" class="space-y-3.5" id="signup-form-element">
                        @Html.AntiForgeryToken()

                        <div class="space-y-1.5">
                            <label for="signup-username" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">Kullanıcı Adı</label>
                            <div class="relative">
                                <input type="text" id="signup-username" name="Username"
                                       class="auth-input"
                                       placeholder="Kullanıcı adı seç" required minlength="3" maxlength="50" pattern="^[a-zA-Z0-9_-]+$">
                                <i data-lucide="at-sign" class="auth-input-icon w-4 h-4"></i>
                            </div>
                            <p class="text-xs text-gray-600">3-50 karakter, harf, rakam, _ ve - kullanabilirsin</p>
                        </div>

                        <div class="space-y-1.5">
                            <label for="signup-email" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">E-posta</label>
                            <div class="relative">
                                <input type="email" id="signup-email" name="Email"
                                       class="auth-input"
                                       placeholder="E-posta adresin" required maxlength="254">
                                <i data-lucide="mail" class="auth-input-icon w-4 h-4"></i>
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label for="signup-displayname" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">Görünür Ad <span class="text-gray-600 normal-case font-normal">(isteğe bağlı)</span></label>
                            <div class="relative">
                                <input type="text" id="signup-displayname" name="DisplayName"
                                       class="auth-input"
                                       placeholder="Görünür adın" maxlength="100">
                                <i data-lucide="user-check" class="auth-input-icon w-4 h-4"></i>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div class="space-y-1.5">
                                <label for="signup-password" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">Şifre</label>
                                <div class="relative">
                                    <input type="password" id="signup-password" name="Password" autocomplete="new-password"
                                           class="auth-input"
                                           placeholder="Min 8 karakter" required minlength="8" maxlength="100">
                                    <i data-lucide="lock" class="auth-input-icon w-4 h-4"></i>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label for="signup-confirm-password" class="block text-gray-400 text-xs font-medium uppercase tracking-wider">Tekrar</label>
                                <div class="relative">
                                    <input type="password" id="signup-confirm-password" name="ConfirmPassword" autocomplete="new-password"
                                           class="auth-input"
                                           placeholder="Şifreni tekrarla" required>
                                    <i data-lucide="lock-keyhole" class="auth-input-icon w-4 h-4"></i>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-2.5 pt-1">
                            <label class="flex items-start gap-2.5 cursor-pointer">
                                <input type="checkbox" id="agree-terms" name="AgreeToTerms"
                                       class="w-4 h-4 rounded text-accent bg-white/10 border-white/20 focus:ring-accent focus:ring-1 mt-0.5 flex-shrink-0" required>
                                <span class="text-gray-400 text-sm leading-snug">
                                    <a href="/terms" class="text-accent hover:underline">Kullanım Şartları</a> ve <a href="/privacy" class="text-accent hover:underline">Gizlilik Politikası</a>'nı kabul ediyorum
                                </span>
                            </label>
                            <label class="flex items-center gap-2.5 cursor-pointer">
                                <input type="checkbox" id="subscribe-newsletter" name="SubscribeToNewsletter"
                                       class="w-4 h-4 rounded text-accent bg-white/10 border-white/20 focus:ring-accent focus:ring-1 flex-shrink-0">
                                <span class="text-gray-400 text-sm">Bültene abone ol <span class="text-gray-600">(isteğe bağlı)</span></span>
                            </label>
                        </div>

                        <button type="submit" class="w-full py-3 rounded-xl font-bold text-sm transition-all duration-200 hover:scale-[1.02] flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-black">
                            <i data-lucide="user-plus" class="w-4 h-4"></i>
                            <span>Hesap Oluştur</span>
                        </button>

                        <div class="text-center pt-3 border-t border-white/10">
                            <p class="text-gray-500 text-sm mb-2">Zaten hesabın var mı?</p>
                            <button type="button" onclick="switchAuthMode('signin')" class="text-sm text-accent hover:text-accent-dark font-semibold transition-colors">
                                Giriş Yap →
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <main id="main-content" class="pt-16">
        @RenderBody()
    </main>

    <!-- Audio Player (Spotify-like fixed bottom bar) -->
    <div id="audio-player" class="audio-player-bar">
        <div class="flex items-center h-full px-4 gap-2">

            <!-- LEFT: Track Info (30%) -->
            <div class="flex items-center gap-3 player-left min-w-0">
                <!-- Cover art -->
                <div class="relative flex-shrink-0 w-14 h-14 bg-muted rounded overflow-hidden" id="track-cover-container">
                    <img id="track-thumbnail" src="" alt="" class="w-full h-full object-cover opacity-0 transition-opacity duration-300">
                    <div id="track-cover-placeholder" class="absolute inset-0 flex items-center justify-center">
                        <i data-lucide="music" class="w-5 h-5 text-gray-500"></i>
                    </div>
                </div>
                <!-- Title & Artist -->
                <div class="min-w-0 flex-1">
                    <div id="track-title" class="text-white text-sm font-medium truncate leading-tight"></div>
                    <div id="track-artist" class="text-gray-400 text-xs truncate mt-0.5 leading-tight"></div>
                </div>
                <!-- Like button -->
                <button class="text-gray-400 hover:text-accent transition-colors flex-shrink-0 p-1" title="Beğen" id="player-like-btn">
                    <i data-lucide="heart" class="w-4 h-4"></i>
                </button>
            </div>

            <!-- CENTER: Controls + Progress (flex-1) -->
            <div class="flex flex-col items-center gap-2 flex-1 min-w-0 px-2">
                <!-- Playback controls -->
                <div class="flex items-center gap-3">
                    <button class="player-btn text-gray-400 hover:text-white" onclick="toggleShuffle()" title="Karıştır">
                        <i data-lucide="shuffle" class="w-4 h-4" id="shuffle-icon"></i>
                    </button>
                    <button class="player-btn text-gray-400 hover:text-white" onclick="playPreviousTrack()" title="Önceki">
                        <i data-lucide="skip-back" class="w-4 h-4"></i>
                    </button>
                    <button class="player-play-btn" onclick="togglePlayPause()" title="Oynat/Duraklat">
                        <i data-lucide="play" class="w-4 h-4" id="play-pause-icon"></i>
                    </button>
                    <button class="player-btn text-gray-400 hover:text-white" onclick="playNextTrack()" title="Sonraki">
                        <i data-lucide="skip-forward" class="w-4 h-4"></i>
                    </button>
                    <button class="player-btn text-gray-400 hover:text-white" onclick="toggleRepeat()" title="Tekrarla">
                        <i data-lucide="repeat" class="w-4 h-4" id="repeat-icon"></i>
                    </button>
                </div>
                <!-- Progress bar -->
                <div class="flex items-center gap-2 w-full max-w-md">
                    <span id="current-time" class="text-xs text-gray-400 w-8 text-right flex-shrink-0">0:00</span>
                    <div class="player-progress-track group" id="progress-bar" onclick="seekAudio(event)">
                        <div id="progress-fill" class="player-progress-fill group-hover:bg-accent" style="width: 0%"></div>
                        <div id="progress-thumb" class="player-progress-thumb" style="left: 0%"></div>
                    </div>
                    <span id="duration" class="text-xs text-gray-400 w-8 flex-shrink-0">0:00</span>
                </div>
            </div>

            <!-- RIGHT: Volume + Close (30%) -->
            <div class="flex items-center justify-end gap-2 player-right">
                <div class="flex items-center gap-2">
                    <button id="volume-button" class="player-btn text-gray-400 hover:text-white" title="Ses">
                        <i data-lucide="volume-2" class="w-4 h-4"></i>
                    </button>
                    <input type="range" id="volume-slider" min="0" max="100" value="75"
                           class="slider player-volume-slider" title="Ses seviyesi">
                </div>
                <button class="player-btn text-gray-400 hover:text-red-400" onclick="hideAudioPlayer()" title="Kapat">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>

        </div>
    </div>

    <!-- Scripts -->
    <script src="~/js/audioPlayer.js?v=@(DateTime.Now.Ticks)"></script>
    <script src="~/js/layout.js?v=@(DateTime.Now.Ticks)"></script>
    <script src="~/js/like-toggle.js?v=@(DateTime.Now.Ticks)"></script>
    <script src="~/js/follow-toggle.js?v=@(DateTime.Now.Ticks)"></script>
    <script src="~/js/search-suggest.js?v=@(DateTime.Now.Ticks)"></script>
    <script src="~/js/site.js?v=@(DateTime.Now.Ticks)"></script>

